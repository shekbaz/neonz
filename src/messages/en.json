  "Cgv": {
    "title": "Terms and conditions of sale",
    "objHeading": "1. Purpose",
    "objText": "These general terms and conditions of sale govern the contractual relationship between NEONZART and its customers for the purchase of LED neon signs, ready-to-buy or custom-made.",
    "ordersHeading": "2. Custom orders",
    "ordersText": "Any custom order is subject to prior validation of the design by the customer via the online configurator. No production begins before explicit confirmation of the final rendering.",
    "paymentHeading": "3. Payment",
    "paymentText": "No online payment is required to place an order. For catalog signs, payment is made in full, in cash, on delivery. For custom signs, a 30% deposit of the total price must be paid before production starts; the remaining balance is paid on delivery.",
    "deliveryHeading": "4. Delivery",
    "deliveryText": "Delivery times are given for information purposes and may vary depending on destination and manufacturing complexity.",
    "withdrawalHeading": "5. Right of withdrawal",
    "withdrawalText": "In accordance with applicable regulations, the right of withdrawal does not apply to custom-made products."
  },
  "Faq": {
    "title": "Frequently asked questions",
    "items": [
      {
        "question": "What is the manufacturing time for a custom sign?",
        "answer": "Allow generally 7 to 14 business days between design validation and shipping."
      },
      {
        "question": "What is the maximum size for a custom sign?",
        "answer": "Custom signs are limited to 90cm in width and 90cm in height."
      },
      {
        "question": "What happens if my design has collisions?",
        "answer": "The configurator automatically detects areas where two neon tubes would be too close and suggests adjustments before you confirm the order."
      },
      {
        "question": "Do you deliver outside Algeria?",
        "answer": "Yes, international delivery is available via carrier; delivery times vary by destination."
      }
    ]
  },
